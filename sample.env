# -----------------------------------------------------------------------------
# Vector — Sample Environment Variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` (ignored by git) and update the values for your
# local environment. These defaults are intended for local development only.
# -----------------------------------------------------------------------------

# -------------------------
# Application URLs
# -------------------------
# Used by Convex auth and as a local CLI fallback for `--app-url`.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------
# Authentication
# -------------------------
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
# Comma-separated list of allowed origins for Better Auth callbacks.
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# -------------------------
# Convex Configuration
# -------------------------
# Local Convex dev typically serves HTTP on :3210 and site/auth helpers on :3211.
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
CONVEX_URL=http://127.0.0.1:3210
CONVEX_SITE_URL=http://127.0.0.1:3211
NEXT_PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211

# -------------------------
# SMTP (Optional)
# -------------------------
# Leave these unset to fall back to console logging for email notifications.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_resend_api_key
SMTP_FROM="Vector <noreply@example.com>"

# -------------------------
# Web Push (Optional)
# -------------------------
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:notifications@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key

# -------------------------
# AI Assistant (Optional)
# -------------------------
# Set these in the Convex environment if you want the assistant enabled.
# OPENROUTER_API_KEY=your_openrouter_api_key
# OPENROUTER_MODEL=moonshotai/kimi-k2.5:nitro

# -------------------------
# GitHub Integration (Optional)
# -------------------------
# Set these in the Convex environment if you want GitHub OAuth or GitHub App sync.
# Webhook secrets are generated per workspace in Vector settings, not from an env var.
# GITHUB_CLIENT_ID=your_github_oauth_client_id
# GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# GITHUB_TOKEN_ENCRYPTION_KEY=replace-with-a-random-secret
