    "lint": "eslint .",
    "auth:generate": "cd convex/betterAuth && pnpm dlx @better-auth/cli generate -y",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "project:setup": "tsx scripts/project-setup.ts",
    "convex:dev": "convex dev",
    "generate:keys": "node generateKeys.mjs"
  },
